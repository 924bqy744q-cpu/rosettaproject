// apps/api/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions       Session[]
  fingerprint    Fingerprint?
  domainJourneys DomainJourney[]
  bridges        CrossDomainBridge[]
}

model Fingerprint {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  
  dominantDomains String[] // Stored as array of strings
  strongSubsumers String[]
  reasoningStyle  String
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id        String   @id @default(uuid())
  userId    String?  // Optional for now (Phase 1 legacy support or partial auth)
  user      User?    @relation(fields: [userId], references: [id])
  
  concept   String   // The raw concept text
  domain    String?
  
  // JSON fields for rich data
  subsumerUsed   String?
  explanation    Json?    // Stores the ExplanationOutput object
  transferTest   Json?    // Stores transfer test and result
  
  timelineEvent LearningTimelineEvent?
  bridgesAsSource CrossDomainBridge[] @relation("BridgeSource")
  bridgesAsTarget CrossDomainBridge[] @relation("BridgeTarget")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Concept {
  id        String   @id @default(uuid())
  raw       String   @unique
  domain    String
  
  // Potential future graph edges or diverse explanations
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DomainJourney {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  domain    String   // e.g., "Python", "Music Theory"
  
  timeline  LearningTimelineEvent[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, domain])
}

model LearningTimelineEvent {
  id              String        @id @default(uuid())
  domainJourneyId String
  domainJourney   DomainJourney @relation(fields: [domainJourneyId], references: [id])
  sessionId       String        @unique
  session         Session       @relation(fields: [sessionId], references: [id])
  
  // Spaced repetition scheduling (SM-2 algorithm)
  nextReviewAt   DateTime?     // null = not yet scored
  intervalDays   Int           @default(1)
  repetitions    Int           @default(0)
  easeFactor     Float         @default(2.5)
  
  createdAt DateTime @default(now())
}

model CrossDomainBridge {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  
  sourceSessionId String
  targetSessionId String
  sourceSession   Session  @relation("BridgeSource", fields: [sourceSessionId], references: [id])
  targetSession   Session  @relation("BridgeTarget", fields: [targetSessionId], references: [id])
  
  sharedPattern   String   // e.g. "composable building blocks"
  confidence      Float    // 0-1 similarity score
  
  createdAt       DateTime @default(now())
  
  @@unique([sourceSessionId, targetSessionId])
}
